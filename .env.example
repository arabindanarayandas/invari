# Invari Docker Environment Configuration
# Copy this file to .env and update the values

# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=invari
POSTGRES_USER=invari
POSTGRES_PASSWORD=invari123

# ============================================
# Application Configuration
# ============================================
PORT=3000

# JWT Secret - CHANGE THIS TO A LONG RANDOM STRING IN PRODUCTION!
# You can generate one with: openssl rand -base64 64
JWT_SECRET=change-this-secret-in-production-use-long-random-string-at-least-32-characters

# CORS Origins (comma-separated)
# Add your frontend domains here
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# ============================================
# Default Admin User (for empty databases)
# ============================================
# Create a default admin user if database is empty (defaults to true)
CREATE_DEFAULT_USER=true

# Customize default admin credentials (optional)
# These are only used when creating the initial admin user
DEFAULT_ADMIN_EMAIL=admin@invari.ai
DEFAULT_ADMIN_PASSWORD=invari123

# ⚠️  IMPORTANT: Change these credentials immediately after first login!

# ============================================
# Optional: Cron Jobs
# ============================================
# Enable background cron jobs (analytics, cleanup, etc.)
ENABLE_CRON=false

# ============================================
# Optional: Database Seeding
# ============================================
# Set to "true" to seed the database with demo data on first run
SEED_DATABASE=false

# ============================================
# Optional: Schema Auto-Sync Configuration
# ============================================
# Maximum number of retries for fetching OpenAPI specs from URLs
SCHEMA_SYNC_MAX_RETRIES=3

# Timeout in milliseconds for fetching OpenAPI specs
SCHEMA_SYNC_TIMEOUT_MS=30000
