{
  "name": "@invari/engine",
  "version": "1.0.0",
  "description": "Invari API Validation Engine",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "db:create": "tsx scripts/create-migration.ts",
    "db:migrate": "tsx scripts/migrate-up.ts",
    "db:rollback": "tsx scripts/migrate-down.ts",
    "db:status": "tsx scripts/migrate-status.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:create-default-user": "tsx scripts/create-default-user.ts"
  },
  "keywords": [
    "proxy",
    "api",
    "openapi",
    "validation"
  ],
  "author": "Arabinda Narayan Das & Dhritiman Nath",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/arabindanarayandas/invari.git",
    "directory": "engine"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "ajv": "^8.16.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.7.2",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "chrono-node": "^2.9.0",
    "compromise": "^14.14.5",
    "compromise-dates": "^3.7.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nanoid": "^5.0.7",
    "node-cron": "^4.2.1",
    "postgres": "^3.4.4",
    "tsx": "^4.16.2",
    "yaml": "^2.8.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.10",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "drizzle-kit": "^0.24.0",
    "typescript": "^5.5.3",
    "vitest": "^4.0.18"
  }
}
