# Demo environment configuration
# This API base URL will be used when building the demo app with: pnpm build:demo

# For production demo deployment (static hosting like Vercel/Netlify):
# Point to your production API server
VITE_API_BASE_URL=https://api.yourdomain.com

# For local demo testing with local API:
# VITE_API_BASE_URL=http://localhost:3000

# For Docker deployment (same origin):
# VITE_API_BASE_URL=
